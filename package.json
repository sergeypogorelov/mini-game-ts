{
  "name": "mini-game-ts",
  "version": "0.0.0",
  "description": "A mini game on TypeScript",
  "scripts": {
    "clean:dist": "rimraf ./dist && mkdir dist",
    "start": "webpack serve --config webpack/webpack.config.dev.js",
    "prebuild": "npm run clean:dist",
    "build": "webpack --config webpack/webpack.config.dev.js",
    "prebuild:prod": "npm run clean:dist",
    "build:prod": "webpack --config webpack/webpack.config.prod.js",
    "lint": "eslint {src/**/*.js,src/**/*.ts}",
    "test": "jest --watchAll",
    "test:coverage": "jest --coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sergeypogorelov/mini-game-ts.git"
  },
  "keywords": [
    "TypeScript",
    "Canvas",
    "Game"
  ],
  "author": "Sergey Pogorelov <sergey.pogorelov.93@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/sergeypogorelov/mini-game-ts/issues"
  },
  "homepage": "https://github.com/sergeypogorelov/mini-game-ts#readme",
  "devDependencies": {
    "@types/jest": "^26.0.20",
    "@typescript-eslint/eslint-plugin": "^4.13.0",
    "@typescript-eslint/parser": "^4.13.0",
    "autoprefixer": "^10.2.1",
    "css-loader": "^5.0.1",
    "eslint": "^7.18.0",
    "eslint-config-prettier": "^7.1.0",
    "eslint-plugin-prettier": "^3.3.1",
    "file-loader": "^6.2.0",
    "html-webpack-plugin": "^4.5.1",
    "jest": "^26.6.3",
    "mini-css-extract-plugin": "^1.3.4",
    "node-sass": "^5.0.0",
    "optimize-css-assets-webpack-plugin": "^5.0.4",
    "postcss-loader": "^4.1.0",
    "precss": "^4.0.0",
    "prettier": "^2.2.1",
    "rimraf": "^3.0.2",
    "sass-loader": "^10.1.1",
    "style-loader": "^2.0.0",
    "ts-jest": "^26.4.4",
    "ts-loader": "^8.0.14",
    "typescript": "^4.1.3",
    "webpack": "^5.13.0",
    "webpack-cli": "^4.3.1",
    "webpack-dev-server": "^3.11.2",
    "webpack-merge": "^5.7.3"
  },
  "eslintConfig": {
    "env": {
      "es6": true,
      "browser": true
    },
    "parser": "@typescript-eslint/parser",
    "parserOptions": {
      "ecmaVersion": 2020,
      "sourceType": "module"
    },
    "extends": [
      "plugin:@typescript-eslint/recommended",
      "prettier/@typescript-eslint",
      "plugin:prettier/recommended"
    ],
    "rules": {
      "prettier/prettier": [
        "error",
        {
          "endOfLine": "auto"
        }
      ]
    }
  },
  "prettier": {
    "semi": true,
    "trailingComma": "all",
    "singleQuote": true,
    "printWidth": 120,
    "tabWidth": 2
  },
  "jest": {
    "preset": "ts-jest",
    "moduleNameMapper": {
      "\\.(jpg|jpeg|png|gif|eot|otf|webp|svg|ttf|woff|woff2|mp4|webm|wav|mp3|m4a|aac|oga)$": "<rootDir>/jest/mock-file.js",
      "\\.(css|scss|less)$": "<rootDir>/jest/mock-style.js"
    },
    "collectCoverageFrom": [
      "src/**/*.ts"
    ]
  }
}
